fig, axes = plt.subplots(1, 2, figsize=(12, 5), sharey=True)

for ax, df, topo in zip(axes, [df_full, df_ring], ['Full Topology', 'Ring Topology']):
    means = [df[df.policy==p]['cost'].mean() for p in policies]
    stds  = [df[df.policy==p]['cost'].std()  for p in policies]
    ax.bar(labels, means, yerr=stds, color=colors, capsize=5,
           edgecolor='white', linewidth=1.2)
    ax.set_title(topo, fontsize=13, fontweight='bold')
    ax.set_xlabel('Migration Policy')
    ax.tick_params(axis='x', rotation=15)

axes[0].set_ylabel('Mean Cost (lower is better)')
axes[0].set_title('Full Topology\n(guided shows no advantage)', fontsize=12)
axes[1].set_title('Ring Topology\nguided wins (-11.2% vs random)', fontsize=12)

fig.suptitle('Exp 2: Rastrigin 30dims — Effect of Topology on Migration Policy',
             fontsize=14, fontweight='bold')
plt.tight_layout()
plt.savefig('figures/fig14_exp2_full_vs_ring.png')
